# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=nexyza.com,www.nexyza.com

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email — Hostinger SMTP ────────────────────────────────────────────────────
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=hello@nexyza.com
EMAIL_HOST_PASSWORD=your-hostinger-email-password
DEFAULT_FROM_EMAIL=Nexyza <hello@nexyza.com>
SERVER_EMAIL=hello@nexyza.com

# ── Database (production) ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///db.sqlite3

# ── Billing ──────────────────────────────────────────────────────────────────
# Set BILLING_ENABLED=True once your LemonSqueezy store is approved and
# variant IDs are filled in below. Until then, pricing shows "Coming Soon".
BILLING_ENABLED=False

# ── Billing — LemonSqueezy ────────────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_PLUS_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PLUS_YEARLY_VARIANT_ID=
LEMONSQUEEZY_PRO_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PRO_YEARLY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ── Google OAuth (optional — for Google Sheets connector) ─────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Site ──────────────────────────────────────────────────────────────────────
SITE_URL=https://nexyza.com

# ── Backups (optional S3/R2 upload) ──────────────────────────────────────────
# Leave blank to keep backups local only
BACKUP_S3_BUCKET=nexyza-backups
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
BACKUP_S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com  # For Cloudflare R2

# ── Microsoft Excel Online connector (optional) ───────────────────────────────
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
