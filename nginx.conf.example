# /etc/nginx/sites-available/nexyza
server {
    listen 80;
    server_name nexyza.com www.nexyza.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name nexyza.com www.nexyza.com;

    ssl_certificate     /etc/letsencrypt/live/nexyza.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/nexyza.com/privkey.pem;

    client_max_body_size 110M;  # Match MAX_UPLOAD_SIZE setting

    # Static files
    location /static/ {
        alias /var/www/nexyza/staticfiles/;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Media files (user uploads)
    location /media/ {
        alias /var/www/nexyza/media/;
    }

    # WebSocket (real-time collaboration)
    location /ws/ {
        proxy_pass         http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
    }

    # App
    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}
